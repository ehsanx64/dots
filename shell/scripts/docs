# Various Documentation
case "$3" in
    lfm)
        gzip -dc /usr/share/doc/lfm/README.gz | vim -R - 
        ;;

    fastapi)
        python -m http.server -d /var/www/html/docs/fastapi 9200
        ;;

    sqlmodel)
        python -m http.server -d /var/www/html/docs/sqlmodel 9201
        ;;


    *)
        echo "docs"
        ;;

esac

